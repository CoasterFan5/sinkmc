{
  "name": "sinkmc-api",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env-file ../../.env",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply sinkmc",
    "db:deploy:remote": "wrangler d1 migrations apply sinkmc --remote",
    "deploy": "pnpm run db:deploy:remote && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@repo/taxonomy": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "wrangler": "^4.106.0"
  }
}
